# SQL Server Express con autenticacion integrada de Windows.
DATABASE_URL=mssql+pyodbc:///?odbc_connect=DRIVER%3DODBC+Driver+17+for+SQL+Server%3BSERVER%3Dlocalhost%5CSQLEXPRESS%3BDATABASE%3DClinix%3BTrusted_Connection%3Dyes%3BEncrypt%3Dno%3BTrustServerCertificate%3Dyes
DEMO_SEED=false

# SQL Server con usuario/password:
# DATABASE_URL=mssql+pyodbc://sa:your_password@localhost:1433/Clinix?driver=ODBC+Driver+17+for+SQL+Server&TrustServerCertificate=yes
SECRET_KEY=change-this-secret-in-production
FRONTEND_URL=http://localhost:5174

# SMTP is optional in local development.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@clinix.com
SMTP_TLS=true
